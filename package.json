  "type": "module",
  "scripts": {
    "dev:obs": "vite build --watch --config vite.obs.dev.config.js",
    "dev:obsm": "vite build --watch --config vite.obsm.dev.config.js",
    "dev": "npm-run-all --parallel dev:obs dev:obsm",
